{
	"root": false,
	"$schema": "https://biomejs.dev/schemas/2.3.12/schema.json",
	"extends": ["../../biome.json"],
	"files": {
		"includes": ["src/**/*.ts", "src/**/*.tsx", "*.mjs", "*.json"]
	},
	"linter": {
		"rules": {
			"correctness": {
				"noUnusedImports": "error"
			},
			"a11y": {
				"noStaticElementInteractions": "off",
				"useKeyWithClickEvents": "off"
			}
		}
	}
}
