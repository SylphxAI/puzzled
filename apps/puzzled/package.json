		"atlas:status": "atlas migrate status --env local",
		"atlas:validate": "atlas migrate validate --env local",
		"atlas:hash": "atlas migrate hash --env local",
		"db:studio": "drizzle-kit studio",
		"db:export": "drizzle-kit export",
