{
	"name": "@sylphx/puzzled",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev --turbopack",
		"build": "next build",
		"build:with-migrate": "atlas migrate apply --env production --baseline 20260222000000 && next build",
		"start": "next start",
		"lint": "biome check .",
