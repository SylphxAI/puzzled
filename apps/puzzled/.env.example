# ===================
# Database (Neon)
# ===================
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# ===================
# Redis (Vercel KV auto-sets these, or use Upstash naming)
# ===================
# KV_REST_API_URL="https://xxx.upstash.io"      # Auto-set by Vercel KV
# KV_REST_API_TOKEN="xxx"                        # Auto-set by Vercel KV
# OR manual:
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="xxx"

# ===================
# Authentication (BetterAuth)
# ===================
BETTER_AUTH_SECRET="your-secret-key-min-32-chars"
# BETTER_AUTH_URL not needed - auto-detected from NEXT_PUBLIC_APP_URL

# Google OAuth (optional - shows button if configured)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Apple OAuth (optional - shows button if configured)
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

# Facebook OAuth (optional - shows button if configured)
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# GitHub OAuth (optional - shows button if configured)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Discord OAuth (optional - shows button if configured)
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# ===================
# File Storage (Vercel Blob)
# ===================
# Get from https://vercel.com/dashboard/stores or auto-set when linking Blob store
BLOB_READ_WRITE_TOKEN="vercel_blob_xxx"

# ===================
# Stripe (Required for payments)
# ===================
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# Optional: Override price IDs (defaults in code if not set)
# STRIPE_PRICE_MONTHLY="price_xxx"
# STRIPE_PRICE_ANNUAL="price_xxx"

# ===================
# Email (Resend)
# ===================
RESEND_API_KEY="re_xxx"
RESEND_FROM_EMAIL="hello@puzzled.gg"

# ===================
# Push Notifications (Web Push)
# Generate keys with: npx web-push generate-vapid-keys
# ===================
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# ===================
# Background Jobs (Upstash QStash)
# ===================
QSTASH_TOKEN="xxx"
QSTASH_CURRENT_SIGNING_KEY="xxx"
QSTASH_NEXT_SIGNING_KEY="xxx"

# ===================
# Cron Jobs
# ===================
# Secret for authenticating cron job requests (Vercel Cron)
# Generate: openssl rand -base64 32 | tr -d '=' | tr '+/' '-_'
CRON_SECRET="xxx"

# ===================
# App
# ===================
# NEXT_PUBLIC_APP_URL defaults to https://puzzled.gg if not set
# Only set for local dev or different domain:
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ===================
# Admin & Initialization
# ===================

# INITIAL_SUPERADMIN_EMAIL - Auto-promote first user to super_admin
# When this email signs up, they become super_admin automatically (one-time)
# After first super_admin exists, this env var is ignored
# Example: INITIAL_SUPERADMIN_EMAIL="you@company.com"
# INITIAL_SUPERADMIN_EMAIL=""

# ===================
# Sentry (Error Monitoring)
# ===================
# Get these from https://sentry.io/settings/[org]/projects/[project]/keys/
NEXT_PUBLIC_SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"

# For source map uploads (optional but recommended)
SENTRY_ORG="your-org"
SENTRY_PROJECT="your-project"
SENTRY_AUTH_TOKEN="sntrys_xxx"

# ===================
# Alerts (Slack/Discord Webhook)
# ===================
# Used for puzzle generation alerts
ALERT_WEBHOOK_URL="https://hooks.slack.com/services/xxx"

# ===================
# AI/LLM (OpenRouter for puzzle generation)
# ===================
OPENROUTER_API_KEY="sk-or-xxx"

# PUZZLE_GENERATOR_MODEL - Initial LLM model for puzzle generation
# Seeds the model setting on first run (one-time, then managed via admin UI)
# Format: provider/model (e.g., anthropic/claude-sonnet-4, openai/gpt-4o)
# Browse models: https://openrouter.ai/models
# Example: PUZZLE_GENERATOR_MODEL="anthropic/claude-sonnet-4"
# PUZZLE_GENERATOR_MODEL=""

# ===================
# Sylphx Platform (Optional - Alternative to BetterAuth)
# ===================
# Enable centralized auth via Sylphx Platform (leave empty to use BetterAuth only)
# Server-side (for token exchange)
SYLPHX_APP_ID="puzzled"
SYLPHX_APP_SECRET=""
SYLPHX_PLATFORM_URL="http://localhost:3001"
# Client-side (for SylphxProvider)
NEXT_PUBLIC_SYLPHX_APP_ID="puzzled"
NEXT_PUBLIC_SYLPHX_PLATFORM_URL="http://localhost:3001"

# ===================
# Analytics (PostHog)
# ===================
# Get from https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY="phc_xxx"
# Optional: Use EU cloud or self-hosted instance
# NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"
