{
	"name": "puzzled-monorepo",
	"version": "0.0.0",
	"private": true,
	"packageManager": "bun@1.3.6",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "turbo dev --filter=@sylphx/puzzled",
		"build": "turbo run build:with-migrate --filter=@sylphx/puzzled",
		"lint": "turbo lint",
		"typecheck": "turbo typecheck",
		"test": "turbo test",
		"check:proto-buf": "bun scripts/check-proto-buf.ts",
		"clean": "turbo clean && rm -rf node_modules",
		"prepare": "git config --unset core.hooksPath >/dev/null 2>&1; lefthook install || true"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.12",
		"@commitlint/cli": "20.3.1",
		"@commitlint/config-conventional": "20.3.1",
		"@types/node": "25.0.10",
		"lefthook": "2.1.9",
		"turbo": "2.7.5"
	}
}
