{
  "name": "@puzzled/sdk-local-retired",
  "version": "0.0.0-retired",
  "description": "RETIRED local fork \u2014 dogfood uses npm @sylphx/sdk@0.27.0 commercial dual-language SDK",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.mjs",
      "require": "./dist/react/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js"
    },
    "./nextjs": {
      "types": "./dist/nextjs/index.d.ts",
      "import": "./dist/nextjs/index.mjs",
      "require": "./dist/nextjs/index.js"
    },
    "./web-analytics": {
      "types": "./dist/web-analytics.d.ts",
      "import": "./dist/web-analytics.mjs",
      "require": "./dist/web-analytics.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node -e \"console.error(\"@puzzled/sdk-local-retired: do not build; use @sylphx/sdk\"); process.exit(1)\"",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "prepare": "node -e \"process.exit(0)\"",
    "prepublishOnly": "tsup",
    "generate:types": "openapi-typescript https://sylphx.com/api/openapi.json -o src/generated/api.d.ts",
    "generate:types:local": "openapi-typescript http://localhost:3002/api/openapi.json -o src/generated/api.d.ts",
    "build:docker": "tsup --no-dts"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5",
    "react": ">=18",
    "react-dom": ">=18",
    "next": ">=14"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "next": {
      "optional": true
    }
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.839.0",
    "@aws-sdk/s3-request-presigner": "^3.839.0",
    "jose": "^6.1.3",
    "openapi-fetch": "0.15.0",
    "rrweb": "^2.0.0-alpha.18",
    "web-vitals": "5.1.0"
  },
  "devDependencies": {
    "@sylphx/ui": "workspace:*",
    "@tanstack/react-query": "^5",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "openapi-typescript": "7.10.1",
    "react": "^19",
    "react-dom": "^19",
    "tsup": "^8.5.1",
    "typescript": "^5"
  },
  "private": true
}
