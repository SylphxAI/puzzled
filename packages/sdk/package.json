{
	"name": "@sylphx/sdk",
	"version": "0.1.0",
	"description": "Sylphx SDK - State-of-the-art platform SDK with pure functions",
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./dist/index.js"
		},
		"./react": {
			"types": "./src/react/index.ts",
			"import": "./dist/react/index.js"
		},
		"./server": {
			"types": "./src/server/index.ts",
			"import": "./dist/server/index.js"
		},
		"./nextjs": {
			"types": "./src/nextjs/index.ts",
			"import": "./dist/nextjs/index.js"
		}
	},
	"main": "./dist/index.js",
	"types": "./src/index.ts",
	"files": ["dist", "src", "ADR.md"],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"test": "bun test",
		"generate:types": "openapi-typescript https://sylphx.com/api/openapi.json -o src/generated/api.d.ts",
		"generate:types:local": "openapi-typescript http://localhost:3002/api/openapi.json -o src/generated/api.d.ts"
	},
	"peerDependencies": {
		"@tanstack/react-query": ">=5",
		"react": ">=18",
		"react-dom": ">=18",
		"next": ">=14"
	},
	"peerDependenciesMeta": {
		"@tanstack/react-query": {
			"optional": true
		},
		"react": {
			"optional": true
		},
		"react-dom": {
			"optional": true
		},
		"next": {
			"optional": true
		}
	},
	"dependencies": {
		"@sylphx/ui": "workspace:*",
		"@vercel/blob": "^2.0.0",
		"jose": "^6.1.3",
		"openapi-fetch": "0.15.0",
		"rrweb": "^2.0.0-alpha.18"
	},
	"devDependencies": {
		"@tanstack/react-query": "^5",
		"@types/node": "^25",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"openapi-typescript": "7.10.1",
		"react": "^19",
		"react-dom": "^19",
		"tsup": "^8.5.1",
		"typescript": "^5"
	}
}
