{
	"name": "@sylphx/sdk",
	"version": "0.1.0",
	"description": "Sylphx SDK - State-of-the-art platform SDK with pure functions",
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./dist/index.js"
		},
		"./react": {
			"types": "./src/react/index.ts",
			"import": "./dist/react/index.js"
		},
		"./server": {
			"types": "./src/server/index.ts",
			"import": "./dist/server/index.js"
		},
		"./nextjs": {
			"types": "./src/nextjs/index.ts",
			"import": "./dist/nextjs/index.js"
		}
	},
	"main": "./dist/index.js",
	"types": "./src/index.ts",
	"files": ["dist", "src", "ADR.md"],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"test": "bun test"
	},
	"peerDependencies": {
		"react": ">=18",
		"react-dom": ">=18",
		"next": ">=14"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": true
		},
		"react-dom": {
			"optional": true
		},
		"next": {
			"optional": true
		}
	},
	"dependencies": {
		"@sylphx/ui": "workspace:*",
		"@trpc/client": "^11.8.1",
		"@trpc/server": "^11.8.1",
		"@vercel/blob": "^2.0.0",
		"jose": "^6.1.3",
		"rrweb": "^2.0.0-alpha.18",
		"superjson": "^2.2.6",
		"use-sync-external-store": "^1.4.0"
	},
	"devDependencies": {
		"@types/node": "^25",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"react": "^19",
		"react-dom": "^19",
		"tsup": "^8.5.1",
		"typescript": "^5"
	}
}
